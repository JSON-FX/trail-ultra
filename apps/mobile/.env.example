# Hosted Supabase — the app uses this from any network (no local Docker needed).
# Anon (publishable) key: Dashboard → Project Settings → API, or:
#   supabase projects api-keys --project-ref ytwdrsmclwghwktpupqd
EXPO_PUBLIC_SUPABASE_URL=https://ytwdrsmclwghwktpupqd.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-cloud-anon-key
# PayMongo publishable (client) key — server holds the secret key
EXPO_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_test_your_paymongo_public_key
